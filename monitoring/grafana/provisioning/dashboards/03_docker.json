      "id": 2,
      "type": "stat",
      "title": "Machine RAM",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "noValue": "0",
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(machine_memory_bytes) or on() vector(0)",
          "refId": "A",
          "legendFormat": "Machine RAM",
          "instant": true,
          "range": false
