{
  "id": null,
  "uid": "pybackend-custom",
  "title": "PyBackend — Full Monitoring",
  "tags": ["pybackend", "fastapi", "custom", "postgres"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "💰 Total Orders Cost (UAH)",
      "description": "Загальна сума всіх замовлень (ціна × кількість товарів)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUAH",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pybackend_total_orders_cost",
          "legendFormat": "Total Cost",
          "refId": "A"
        }
      ]
    },
    {
