    {
      "id": 2,
      "type": "stat",
      "title": "RPS (усі)",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "noValue": "0",
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum(rate(http_requests_total{job=\"fastapi\"}[5m]))) or on() vector(0)",
          "refId": "A",
          "legendFormat": "RPS (усі)",
          "instant": true,
          "range": false
        }
      ]
