{
  "uid": "pybackend-custom",
  "title": "PyBackend — Custom Metrics",
  "tags": [
    "pybackend",
    "custom"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🎯 Кастомні бізнес-метрики PyBackend",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "💰 Total Orders Cost",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "noValue": "0",
          "unit": "currencyUAH"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(last_over_time(pybackend_total_orders_cost[5m])) or on() vector(0)",
          "refId": "A",
          "legendFormat": "💰 Total Orders Cost",
          "instant": true,
          "range": false
        }
      ]
    },
